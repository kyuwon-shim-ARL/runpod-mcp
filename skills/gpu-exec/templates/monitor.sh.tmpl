#!/usr/bin/env bash
# monitor.sh — GPU pipeline orchestrator
# Generated by generate_pipeline.py from monitor.sh.tmpl
# Pipeline: __PIPELINE_ID__
# Run via crontab: */10 * * * * bash /path/to/monitor.sh >> /path/to/monitor.log 2>&1 # gpu-exec-__PIPELINE_ID__
set -euo pipefail

# ── Configuration (substituted by generate_pipeline.py) ─────────────────────
PIPELINE_ID="__PIPELINE_ID__"
PROJECT_DIR="__PROJECT_DIR__"
STATE_FILE="__STATE_FILE__"
LOG_FILE="__LOG_FILE__"
NOTIFY_EMAIL="__NOTIFY_EMAIL__"
GPU_TYPE_ID="__GPU_TYPE_ID__"
POD_IMAGE="__POD_IMAGE__"
NETWORK_VOL_ID="__NETWORK_VOL_ID__"
SSH_KEY_PATH="__SSH_KEY_PATH__"
SPEC_FILE="__SPEC_FILE__"
ENV_FILE="__ENV_FILE__"
MAX_RUNTIME_HOURS="__MAX_RUNTIME_HOURS__"
GATE_EVAL="$(dirname "$0")/gate_eval.py"
STATE_HELPER="$(dirname "$0")/state_helper.py"
OMC_DIR="$(dirname "$STATE_FILE")"

# ── PID lock (prevent concurrent cron runs) ──────────────────────────────────
LOCKFILE="$OMC_DIR/monitor.lock"
exec 9>"$LOCKFILE"
flock -n 9 || { echo "$(date -u +%FT%TZ) [SKIP] already running, exiting"; exit 0; }
trap "flock -u 9; rm -f '$LOCKFILE'" EXIT

# ── Logging ───────────────────────────────────────────────────────────────────
log() { echo "$(date -u +%FT%TZ) [$PIPELINE_ID] $*"; }

# ── ENV_FILE guard ────────────────────────────────────────────────────────────
if [[ ! -f "$ENV_FILE" ]]; then
    log "ERROR: ENV_FILE not found: $ENV_FILE"
    python3 "$STATE_HELPER" set_state "$STATE_FILE" ERROR 2>/dev/null || true
    log "Pipeline stopped: ENV_FILE missing"
    exit 2
fi
# shellcheck source=/dev/null
source "$ENV_FILE"

# Resolve mode after ENV_FILE is sourced (RUNPOD_API_KEY may be needed)
MODE="$(python3 "$STATE_HELPER" get_mode "$SPEC_FILE")"

if [[ "$MODE" == "runpod" && -z "${RUNPOD_API_KEY:-}" ]]; then
    log "ERROR: RUNPOD_API_KEY not set in $ENV_FILE"
    exit 2
fi

# ── Notifications ─────────────────────────────────────────────────────────────
send_notification() {
    local event="$1" msg="$2"
    [[ -z "$NOTIFY_EMAIL" ]] && return 0
    send-email "$NOTIFY_EMAIL" "[gpu-exec] $PIPELINE_ID: $event" "$msg" 2>/dev/null || \
        log "WARN: email notification failed (non-blocking)"
}

# ── Cron self-removal (idempotent) ────────────────────────────────────────────
remove_cron() {
    local marker="# gpu-exec-$PIPELINE_ID"
    local current
    current=$(crontab -l 2>/dev/null || true)
    if echo "$current" | grep -qF "$marker"; then
        echo "$current" | grep -vF "$marker" | crontab -
        log "Cron entry removed"
    fi
}

# ── State helpers (delegate to state_helper.py — no inline python3 -c) ───────
get_state()       { python3 "$STATE_HELPER" get_state       "$STATE_FILE"; }
get_field()       { python3 "$STATE_HELPER" get_field       "$STATE_FILE" "$1"; }
set_field()       { python3 "$STATE_HELPER" set_field       "$STATE_FILE" "$1" "${2:-}"; }
increment_retry() { python3 "$STATE_HELPER" increment_retry "$STATE_FILE"; }

set_state() {
    python3 "$STATE_HELPER" set_state "$STATE_FILE" "$1"
    log "State → $1"
}

# ── Runtime guard ─────────────────────────────────────────────────────────────
check_runtime() {
    [[ -z "$MAX_RUNTIME_HOURS" ]] && return 0
    local started
    started=$(get_field started_at)
    [[ -z "$started" ]] && return 0
    local elapsed_hours
    elapsed_hours=$(python3 "$STATE_HELPER" elapsed_hours "$started" 2>/dev/null || echo 0)
    if (( elapsed_hours >= MAX_RUNTIME_HOURS )); then
        log "ERROR: max_runtime_hours ($MAX_RUNTIME_HOURS) exceeded (${elapsed_hours}h elapsed)"
        handle_error "Runtime limit exceeded"
    fi
}

# ── RunPod API ────────────────────────────────────────────────────────────────
api_call_with_retry() {
    local query="$1"
    local retries=3 wait=10 response rc
    for i in $(seq 1 $retries); do
        response=$(curl -sf -m 30 -X POST https://api.runpod.io/graphql \
            -H "Content-Type: application/json" \
            -H "Authorization: Bearer $RUNPOD_API_KEY" \
            -d "{\"query\": \"$query\"}" 2>&1) && rc=0 || rc=$?
        if [[ $rc -eq 0 && -n "$response" ]]; then
            echo "$response"; return 0
        fi
        log "WARN: API attempt $i/$retries failed (rc=$rc), retry in ${wait}s"
        sleep $wait; wait=$((wait * 2))
    done
    log "ERROR: API failed after $retries attempts"
    return 1
}

# ── Error/fail handlers ───────────────────────────────────────────────────────
handle_error() {
    local msg="${1:-Unknown error}"
    log "ERROR: $msg"
    set_state "ERROR"
    local pod_id; pod_id=$(get_field pod_id)
    if [[ "$MODE" == "runpod" && -n "$pod_id" ]]; then
        log "Deleting pod $pod_id"
        api_call_with_retry "mutation { podTerminate(input: {podId: \"$pod_id\"}) }" 2>/dev/null || \
            log "WARN: pod termination failed — delete manually"
    fi
    send_notification "ERROR" "$msg\nPipeline: $PIPELINE_ID\nLog: $LOG_FILE"
    remove_cron
    exit 1
}

handle_gate_fail() {
    local phase_id="$1" msg="${2:-Gate failed}"
    log "GATE_FAIL: $phase_id — $msg"
    set_state "GATE_FAIL"
    local pod_id; pod_id=$(get_field pod_id)
    if [[ "$MODE" == "runpod" && -n "$pod_id" ]]; then
        log "Deleting pod $pod_id (gate fail)"
        api_call_with_retry "mutation { podTerminate(input: {podId: \"$pod_id\"}) }" 2>/dev/null || true
        set_field pod_id ""
    fi
    send_notification "GATE_FAIL" "Phase $phase_id gate failed.\n$msg\nUse --resume to retry."
    remove_cron
    exit 1
}

# ── Phase spec helper ─────────────────────────────────────────────────────────
get_phase() {
    local idx; idx=$(get_field current_phase_index)
    python3 "$STATE_HELPER" get_phase "$SPEC_FILE" "$idx" "$1"
}

# ── State machine ─────────────────────────────────────────────────────────────
main() {
    local state; state=$(get_state)
    check_runtime

    case "$state" in

    IDLE)
        log "Starting pipeline (mode=$MODE)"
        set_field started_at "$(date -u +%FT%TZ)"
        if [[ "$MODE" == "local" ]]; then
            set_state "RUNNING"
            handle_running
        else
            set_state "CREATING_POD"
            handle_creating_pod
        fi
        ;;

    CREATING_POD)
        [[ "$MODE" != "runpod" ]] && { log "SKIP: local mode"; set_state "RUNNING"; handle_running; return; }
        handle_creating_pod
        ;;

    WAITING_FOR_SSH)
        [[ "$MODE" != "runpod" ]] && { set_state "RUNNING"; handle_running; return; }
        handle_waiting_for_ssh
        ;;

    POD_READY|UPLOADING)
        [[ "$MODE" != "runpod" ]] && { set_state "RUNNING"; handle_running; return; }
        handle_uploading
        ;;

    RUNNING)
        handle_running
        ;;

    POLLING)
        handle_polling
        ;;

    GATE_CHECK)
        handle_gate_check
        ;;

    DOWNLOADING)
        [[ "$MODE" == "local" ]] && { set_state "PHASE_DONE"; handle_phase_done; return; }
        handle_downloading
        ;;

    PHASE_DONE)
        handle_phase_done
        ;;

    PIPELINE_DONE|GATE_FAIL|ERROR)
        log "Terminal state: $state — exiting"
        ;;

    *)
        log "ERROR: Unknown state: $state"
        handle_error "Unknown state: $state"
        ;;
    esac
}

handle_creating_pod() {
    log "Creating RunPod pod..."
    local response pod_id
    response=$(api_call_with_retry "mutation { podFindAndDeployOnDemand(input: { gpuTypeId: \\\"$GPU_TYPE_ID\\\", imageName: \\\"$POD_IMAGE\\\", networkVolumeId: \\\"$NETWORK_VOL_ID\\\", gpuCount: 1 }) { id } }") || \
        handle_error "Pod creation failed"
    pod_id=$(echo "$response" | python3 -c "import sys,json; print(json.load(sys.stdin)['data']['podFindAndDeployOnDemand']['id'])" 2>/dev/null) || \
        handle_error "Could not parse pod_id from response"
    set_field pod_id "$pod_id"
    log "Pod created: $pod_id"
    set_state "WAITING_FOR_SSH"
}

handle_waiting_for_ssh() {
    local pod_id pod_ip retry_count
    pod_id=$(get_field pod_id)
    retry_count=$(get_field retry_count)
    if (( retry_count >= 20 )); then
        handle_error "SSH wait timeout after 20 attempts (~3h)"
    fi
    local response
    response=$(api_call_with_retry "{ pod(input: {podId: \\\"$pod_id\\\"}) { runtime { uptimeInSeconds ports { ip isIpPublic privatePort publicPort type } } } }") || \
        { increment_retry; log "WARN: Could not get pod info (retry $((retry_count+1))/20)"; return; }
    pod_ip=$(echo "$response" | python3 -c "
import sys,json
data = json.load(sys.stdin)
ports = data.get('data',{}).get('pod',{}).get('runtime',{}).get('ports',[])
for p in ports:
    if p.get('privatePort') == 22 and p.get('isIpPublic'):
        print(p['ip']); break
" 2>/dev/null || true)
    if [[ -z "$pod_ip" ]]; then
        increment_retry
        log "WARN: Pod not ready yet (retry $((retry_count+1))/20)"
        return
    fi
    if ssh -o StrictHostKeyChecking=no -o ConnectTimeout=5 -i "$SSH_KEY_PATH" "root@$pod_ip" true 2>/dev/null; then
        set_field pod_ip "$pod_ip"
        set_field retry_count 0
        log "SSH ready: $pod_ip"
        set_state "POD_READY"
        handle_uploading
    else
        increment_retry
        log "WARN: SSH not ready yet (retry $((retry_count+1))/20)"
    fi
}

handle_uploading() {
    local pod_ip phase_script remote_dest upload_paths
    pod_ip=$(get_field pod_ip)
    phase_script=$(get_phase script)
    local idx; idx=$(get_field current_phase_index)
    remote_dest=$(python3 "$STATE_HELPER" get_upload_dest "$SPEC_FILE" "$idx")
    upload_paths=$(python3 "$STATE_HELPER" get_upload_paths "$SPEC_FILE" "$idx" | sed "s|^|$PROJECT_DIR/|")
    log "Uploading to $pod_ip:$remote_dest"
    while IFS= read -r lpath; do
        [[ -z "$lpath" ]] && continue
        rsync -az -e "ssh -i $SSH_KEY_PATH -o StrictHostKeyChecking=no" \
            "$lpath" "root@$pod_ip:$remote_dest/" || handle_error "rsync upload failed: $lpath"
    done <<< "$upload_paths"
    set_state "RUNNING"
    handle_running
}

handle_running() {
    local phase_id phase_script sentinel_dir
    phase_id=$(get_phase id)
    phase_script=$(get_phase script)
    sentinel_dir=$(get_phase sentinel_dir)
    [[ -z "$sentinel_dir" ]] && sentinel_dir="$PROJECT_DIR"

    if [[ "$MODE" == "local" ]]; then
        log "Starting local: $phase_script"
        mkdir -p "$sentinel_dir"
        DONE_DIR="$sentinel_dir" nohup bash "$PROJECT_DIR/$phase_script" \
            > "$LOG_FILE.phase-$phase_id" 2>&1 &
        echo $! > "$OMC_DIR/phase.pid"
        log "Started (PID=$!), sentinel: $sentinel_dir/.done"
    else
        local pod_ip; pod_ip=$(get_field pod_ip)
        local remote_dest="/workspace/project"
        log "Starting remote: $phase_script on $pod_ip"
        ssh -o StrictHostKeyChecking=no -i "$SSH_KEY_PATH" "root@$pod_ip" \
            "cd $remote_dest && DONE_DIR=$remote_dest nohup bash $phase_script > train.log 2>&1 &"
    fi
    set_state "POLLING"
}

handle_polling() {
    local phase_id sentinel_dir done_path
    phase_id=$(get_phase id)
    sentinel_dir=$(get_phase sentinel_dir)
    [[ -z "$sentinel_dir" ]] && sentinel_dir="$PROJECT_DIR"
    done_path="$sentinel_dir/.done"

    local done=false
    if [[ "$MODE" == "local" ]]; then
        [[ -f "$done_path" ]] && done=true
    else
        local pod_ip; pod_ip=$(get_field pod_ip)
        ssh -o StrictHostKeyChecking=no -o ConnectTimeout=5 -i "$SSH_KEY_PATH" \
            "root@$pod_ip" "test -f $done_path" 2>/dev/null && done=true
    fi

    if $done; then
        log "Sentinel .done detected for phase $phase_id"
        set_state "GATE_CHECK"
        handle_gate_check
    else
        log "POLL: $phase_id not done yet"
    fi
}

handle_gate_check() {
    local phase_id metrics_file condition
    phase_id=$(get_phase id)
    local idx; idx=$(get_field current_phase_index)
    local gate_meta; gate_meta=$(python3 "$STATE_HELPER" get_gate_meta "$SPEC_FILE" "$idx")
    metrics_file=$(echo "$gate_meta" | sed -n '1p')
    condition=$(echo "$gate_meta" | sed -n '2p')

    if [[ -z "$metrics_file" || -z "$condition" ]]; then
        log "No gate defined for $phase_id — auto-pass"
        set_state "DOWNLOADING"
        handle_downloading
        return
    fi
    local full_metrics_path="$PROJECT_DIR/$metrics_file"
    log "Gate check: $condition against $full_metrics_path"
    local gate_output gate_rc
    gate_output=$(python3 "$GATE_EVAL" --metrics "$full_metrics_path" \
        --condition "$condition" --phase "$phase_id" 2>/dev/null) && gate_rc=0 || gate_rc=$?
    log "Gate result (rc=$gate_rc): $gate_output"

    if [[ $gate_rc -eq 0 ]]; then
        python3 "$STATE_HELPER" record_phase_result "$STATE_FILE" "$phase_id"
        send_notification "PHASE_DONE" "Phase $phase_id gate PASSED.\n$gate_output"
        set_state "DOWNLOADING"
        handle_downloading
    elif [[ $gate_rc -eq 1 ]]; then
        handle_gate_fail "$phase_id" "$gate_output"
    else
        handle_error "Gate evaluator error (exit 2): $gate_output"
    fi
}

handle_downloading() {
    if [[ "$MODE" == "local" ]]; then
        set_state "PHASE_DONE"
        handle_phase_done
        return
    fi
    local pod_ip; pod_ip=$(get_field pod_ip)
    local idx; idx=$(get_field current_phase_index)
    local outputs
    outputs=$(python3 "$STATE_HELPER" get_outputs "$SPEC_FILE" "$idx")
    log "Downloading outputs from $pod_ip"
    while IFS= read -r out; do
        [[ -z "$out" ]] && continue
        local local_dir; local_dir="$PROJECT_DIR/$(dirname "$out")"
        mkdir -p "$local_dir"
        rsync -az -e "ssh -i $SSH_KEY_PATH -o StrictHostKeyChecking=no" \
            "root@$pod_ip:/workspace/project/$out" "$local_dir/" || \
            log "WARN: download failed for $out (continuing)"
    done <<< "$outputs"
    set_state "PHASE_DONE"
    handle_phase_done
}

handle_phase_done() {
    local idx phase_count
    idx=$(get_field current_phase_index)
    phase_count=$(python3 "$STATE_HELPER" phase_count "$SPEC_FILE")
    local next_idx=$(( idx + 1 ))

    if (( next_idx < phase_count )); then
        log "Phase $idx done — advancing to phase $next_idx"
        set_field current_phase_index "$next_idx"
        set_field pod_id ""
        set_field retry_count 0
        if [[ "$MODE" == "runpod" ]]; then
            set_state "CREATING_POD"
            handle_creating_pod
        else
            set_state "RUNNING"
            handle_running
        fi
    else
        log "All phases complete — PIPELINE_DONE"
        set_state "PIPELINE_DONE"
        send_notification "PIPELINE_DONE" "Pipeline $PIPELINE_ID completed successfully."
        remove_cron
    fi
}

main "$@"
