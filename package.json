{
  "name": "runpod-tools-mcp",
  "version": "0.2.0",
  "description": "MCP server for RunPod GPU pod management - full lifecycle, SSH, file transfer, GPU stock checking",
  "keywords": [
    "mcp",
    "runpod",
    "gpu",
    "claude-code",
    "ai"
  ],
  "license": "MIT",
  "author": "Kyuwon Shim",
  "type": "module",
  "bin": {
    "runpod-tools-mcp": "dist/index.js",
    "runpod-watchdog": "dist/watchdog.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/__tests__/",
    "!dist/runpod-mcp.mjs"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/runpod-mcp.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
